# Environment Variables for TradeMachineEx
#
# QUICK START:
# 1. Copy .env.development to .env: `cp .env.development .env`
# 2. Customize values below as needed
# 3. Run: `docker-compose up`
#
# WORKFLOW:
# - .env.development = Safe template (committed to git)
# - .env = Your personal copy (gitignored)
# - docker-compose.yml reads from .env automatically

# Frontend url, needed for emails
FRONTEND_URL=https://your_frontend_url

# Database Configuration - Dual Repo Pattern
# For local development, use localhost with different ports
# For production with Docker networking, use container names
DATABASE_USER=trader_dev
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=trade_machine
DATABASE_POOL_SIZE=10

# Production database (defaults to localhost for local dev)
PROD_DATABASE_HOST=localhost
PROD_DATABASE_PORT=5432

# Staging database (defaults to localhost for local dev)
STAGING_DATABASE_HOST=localhost
STAGING_DATABASE_PORT=5435

# Legacy: DATABASE_HOST is used as fallback if PROD/STAGING_DATABASE_HOST not set
DATABASE_HOST=localhost
DATABASE_SCHEMA=public

# Phoenix Configuration
PORT=4000
PHX_HOST=localhost
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret

# Minor League Sheet (public CSV export via Req)
MINOR_LEAGUE_SHEET_ID=your_minor_league_sheet_id_here
# Optional: GID for the specific tab (defaults to 806978055 if not set)
# MINOR_LEAGUE_SHEET_GID=806978055

# Logging
LOG_LEVEL=info

# Oban Job Processing
ENABLE_CRON=false
OBAN_MINORS_SYNC_CONCURRENCY=1
OBAN_DRAFT_SYNC_CONCURRENCY=1

# Monitoring (PromEx)
GRAFANA_HOST=http://localhost:3000
GRAFANA_TOKEN=your_grafana_token
OTEL_SERVICE_NAME=trademachine-elixir
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_VERSION=0.1.0


# Email Configuration (Brevo/SendInBlue)
BREVO_API_KEY=your_brevo_api_key_here
# ESPN Fantasy API Configuration
ESPN_COOKIE=your_espn_s2_cookie_here
ESPN_SWID=your_espn_swid_here
ESPN_LEAGUE_ID=545
ESPN_SEASON_YEAR=2025