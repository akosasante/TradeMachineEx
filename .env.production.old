# Production environment variables for TradeMachine Elixir application
# Copy this file to production host's .env and update the values as needed
# Do NOT commit sensitive information to version control

# Frontend url, needed for emails
FRONTEND_URL=https://your_production_frontend_url

# Database Configuration
DATABASE_USER=trader_dev
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=trade_machine
DATABASE_HOST=host_of_your_production_db
DATABASE_PORT=port_of_your_db (default 5432)
DATABASE_POOL_SIZE=10
DATABASE_SCHEMA=postgres_schema_name

# Phoenix Configuration
PORT=port_exposed_in_docker_container
PHX_HOST=localhost
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret

# Google Sheets Integration
GOOGLE_SHEETS_CREDS_PATH=./path_to_Google_Sheets_Credentials.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Logging
LOG_LEVEL=info

# Oban Job Processing
ENABLE_CRON=false
OBAN_MINORS_SYNC_CONCURRENCY=1
OBAN_DRAFT_SYNC_CONCURRENCY=1

# Monitoring (PromEx)
GRAFANA_HOST=real_grafana_host_url
GRAFANA_TOKEN=your_grafana_token
#OTEL_SERVICE_NAME=trademachine-elixir
#OTEL_EXPORTER_OTLP_ENDPOINT=otlp_endpoint_url
#OTEL_SERVICE_VERSION=0.1.0
# Optional trace sampling (10% for development)
#OTEL_TRACES_SAMPLER=traceidratio
#OTEL_TRACES_SAMPLER_ARG=0.1


# Email Configuration (Brevo/SendInBlue)
BREVO_API_KEY=your_brevo_api_key_here